# --- PostgreSQL (required) ---
# Local: docker compose up -d, then:
DATABASE_URL="postgresql://nobudget:nobudget@localhost:5432/nobudget?schema=public"
# Same as DATABASE_URL unless you use Supabase Transaction pooler on DATABASE_URL (port 6543 + ?pgbouncer=true).
# Then set DIRECT_URL to the direct connection (Settings → Database → URI, port 5432, no pgbouncer).
DIRECT_URL="postgresql://nobudget:nobudget@localhost:5432/nobudget?schema=public"

# Railway: add the Postgres plugin and copy DATABASE_PUBLIC_URL or DATABASE_URL into both vars if it is a single direct URL.

# Supabase: Project Settings → Database
# - Use "Connection pooling" / Transaction mode for DATABASE_URL when you want PgBouncer.
# - Use "Direct connection" for DIRECT_URL (migrations + prisma migrate deploy).

# --- App ---
NODE_ENV=development
PORT=3000

# Production: min 24 chars, unique secret (openssl rand -base64 32)
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES="7d"

# Optional: comma-separated origins. If unset, CORS mirrors request origin (fine when UI is served from this same app).
# CORS_ORIGIN="https://your-app.up.railway.app"

# Optional: market quotes for inversiones (Twelve Data)
# TWELVE_DATA_API_KEY=
